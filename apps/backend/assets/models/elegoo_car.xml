<mujoco model="elegoo_smart_car_v4">
  <!--
    Elegoo Smart Robot Car V4.0 — MuJoCo MJCF model
    Approximate dimensions from product specs:
      Chassis: 24cm x 15cm x 3cm (L x W x H)
      Wheels: 6.5cm diameter, 2.5cm wide
      Wheelbase: ~15cm (center to center)
      Track width: ~17cm (wheel center to wheel center)
      Total mass: ~800g with battery

    This uses geometric primitives. Replace geom meshes with
    STL files from the GrabCAD STEP export for visual fidelity.
  -->

  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.001" gravity="0 0 -9.81" solver="Newton" iterations="50" tolerance="1e-10">
    <flag warmstart="enable"/>
  </option>

  <default>
    <joint damping="0.1" armature="0.01"/>
    <geom friction="1.0 0.005 0.001" condim="3" solimp="0.95 0.99 0.001" solref="0.02 1"/>
    <motor ctrlrange="-10 10"/>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.2 0.25" rgb2="0.15 0.15 0.2" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="10 10" texuniform="true"/>
    <material name="chassis_mat" rgba="0.15 0.15 0.2 1"/>
    <material name="pcb_mat" rgba="0.05 0.35 0.15 1"/>
    <material name="wheel_mat" rgba="0.1 0.1 0.1 1"/>
    <material name="tire_mat" rgba="0.2 0.2 0.2 1"/>
    <material name="sensor_mat" rgba="0.3 0.3 0.35 1"/>
    <material name="motor_mat" rgba="0.6 0.55 0.1 1"/>
    <material name="led_mat" rgba="0.8 0.1 0.1 1"/>
    <material name="camera_mat" rgba="0.2 0.2 0.3 1"/>
    <material name="battery_mat" rgba="0.15 0.15 0.4 1"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom name="floor" type="plane" size="5 5 0.1" material="grid_mat"/>

    <!-- ============================================================ -->
    <!-- Chassis (free-floating base) -->
    <!-- ============================================================ -->
    <body name="chassis" pos="0 0 0.055">
      <freejoint name="root"/>
      <inertial pos="0 0 0" mass="0.5" diaginertia="0.002 0.003 0.004"/>

      <!-- Lower chassis plate -->
      <geom name="chassis_lower" type="box" size="0.12 0.075 0.015"
            pos="0 0 0" material="chassis_mat"/>

      <!-- Upper chassis plate (PCB level) -->
      <geom name="chassis_upper" type="box" size="0.10 0.065 0.008"
            pos="0 0 0.03" material="pcb_mat"/>

      <!-- Standoffs between plates -->
      <geom name="standoff_fl" type="cylinder" size="0.004 0.015" pos="0.07 0.05 0.015" material="sensor_mat"/>
      <geom name="standoff_fr" type="cylinder" size="0.004 0.015" pos="0.07 -0.05 0.015" material="sensor_mat"/>
      <geom name="standoff_rl" type="cylinder" size="0.004 0.015" pos="-0.07 0.05 0.015" material="sensor_mat"/>
      <geom name="standoff_rr" type="cylinder" size="0.004 0.015" pos="-0.07 -0.05 0.015" material="sensor_mat"/>

      <!-- Battery pack (between plates) -->
      <geom name="battery" type="box" size="0.035 0.03 0.012"
            pos="-0.03 0 0.015" material="battery_mat" mass="0.15"/>

      <!-- Arduino Uno (on upper plate) -->
      <geom name="arduino" type="box" size="0.035 0.027 0.005"
            pos="0 0 0.043" material="pcb_mat"/>

      <!-- Motor driver shield -->
      <geom name="motor_shield" type="box" size="0.035 0.027 0.004"
            pos="0 0 0.05" material="pcb_mat"/>

      <!-- Ultrasonic sensor mount (front) -->
      <geom name="ultrasonic_left_eye" type="cylinder" size="0.008 0.005"
            pos="0.12 0.013 0.06" material="sensor_mat"/>
      <geom name="ultrasonic_right_eye" type="cylinder" size="0.008 0.005"
            pos="0.12 -0.013 0.06" material="sensor_mat"/>

      <!-- Servo mount for ultrasonic -->
      <geom name="servo_base" type="box" size="0.012 0.012 0.012"
            pos="0.10 0 0.045" material="motor_mat"/>

      <!-- Camera module (V4 has camera) -->
      <geom name="camera" type="box" size="0.015 0.015 0.008"
            pos="0.11 0 0.07" material="camera_mat"/>

      <!-- IR sensors (bottom, line following) -->
      <geom name="ir_left" type="box" size="0.005 0.003 0.002"
            pos="0.10 0.02 -0.015" material="led_mat"/>
      <geom name="ir_center" type="box" size="0.005 0.003 0.002"
            pos="0.10 0 -0.015" material="led_mat"/>
      <geom name="ir_right" type="box" size="0.005 0.003 0.002"
            pos="0.10 -0.02 -0.015" material="led_mat"/>

      <!-- IMU sensor site (on chassis, near Arduino) -->
      <site name="imu_site" pos="0 0 0.03" size="0.005"/>

      <!-- ======================================================== -->
      <!-- Left Front Wheel + Motor -->
      <!-- ======================================================== -->
      <body name="wheel_lf" pos="0.06 0.085 -0.01">
        <joint name="joint_lf" type="hinge" axis="0 1 0"/>
        <inertial pos="0 0 0" mass="0.04" diaginertia="0.00002 0.00003 0.00002"/>
        <!-- Motor housing -->
        <geom name="motor_lf" type="box" size="0.015 0.012 0.01"
              pos="0 -0.015 0" material="motor_mat"/>
        <!-- Wheel -->
        <geom name="wheel_lf_geom" type="cylinder" size="0.0325 0.0125"
              material="tire_mat" friction="1.2 0.005 0.001"/>
      </body>

      <!-- ======================================================== -->
      <!-- Right Front Wheel + Motor -->
      <!-- ======================================================== -->
      <body name="wheel_rf" pos="0.06 -0.085 -0.01">
        <joint name="joint_rf" type="hinge" axis="0 1 0"/>
        <inertial pos="0 0 0" mass="0.04" diaginertia="0.00002 0.00003 0.00002"/>
        <geom name="motor_rf" type="box" size="0.015 0.012 0.01"
              pos="0 0.015 0" material="motor_mat"/>
        <geom name="wheel_rf_geom" type="cylinder" size="0.0325 0.0125"
              material="tire_mat" friction="1.2 0.005 0.001"/>
      </body>

      <!-- ======================================================== -->
      <!-- Left Rear Wheel + Motor -->
      <!-- ======================================================== -->
      <body name="wheel_lr" pos="-0.06 0.085 -0.01">
        <joint name="joint_lr" type="hinge" axis="0 1 0"/>
        <inertial pos="0 0 0" mass="0.04" diaginertia="0.00002 0.00003 0.00002"/>
        <geom name="motor_lr" type="box" size="0.015 0.012 0.01"
              pos="0 -0.015 0" material="motor_mat"/>
        <geom name="wheel_lr_geom" type="cylinder" size="0.0325 0.0125"
              material="tire_mat" friction="1.2 0.005 0.001"/>
      </body>

      <!-- ======================================================== -->
      <!-- Right Rear Wheel + Motor -->
      <!-- ======================================================== -->
      <body name="wheel_rr" pos="-0.06 -0.085 -0.01">
        <joint name="joint_rr" type="hinge" axis="0 1 0"/>
        <inertial pos="0 0 0" mass="0.04" diaginertia="0.00002 0.00003 0.00002"/>
        <geom name="motor_rr" type="box" size="0.015 0.012 0.01"
              pos="0 0.015 0" material="motor_mat"/>
        <geom name="wheel_rr_geom" type="cylinder" size="0.0325 0.0125"
              material="tire_mat" friction="1.2 0.005 0.001"/>
      </body>

    </body>
  </worldbody>

  <!-- ============================================================ -->
  <!-- Actuators — 4 DC motors (velocity control) -->
  <!-- Left side motors share speed, right side motors share speed -->
  <!-- ============================================================ -->
  <actuator>
    <velocity name="motor_lf" joint="joint_lf" kv="0.5"/>
    <velocity name="motor_rf" joint="joint_rf" kv="0.5"/>
    <velocity name="motor_lr" joint="joint_lr" kv="0.5"/>
    <velocity name="motor_rr" joint="joint_rr" kv="0.5"/>
  </actuator>

  <!-- ============================================================ -->
  <!-- Sensors -->
  <!-- ============================================================ -->
  <sensor>
    <!-- Wheel velocities -->
    <jointvel name="vel_lf" joint="joint_lf"/>
    <jointvel name="vel_rf" joint="joint_rf"/>
    <jointvel name="vel_lr" joint="joint_lr"/>
    <jointvel name="vel_rr" joint="joint_rr"/>
    <!-- Chassis IMU -->
    <accelerometer name="imu_accel" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
    <!-- Chassis position/velocity -->
    <framepos name="chassis_pos" objtype="body" objname="chassis"/>
    <framequat name="chassis_quat" objtype="body" objname="chassis"/>
    <framelinvel name="chassis_linvel" objtype="body" objname="chassis"/>
    <frameangvel name="chassis_angvel" objtype="body" objname="chassis"/>
  </sensor>


</mujoco>
